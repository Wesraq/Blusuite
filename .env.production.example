# =============================================================
# BLU Suite — Production Environment Template
# Copy this to /opt/blusuite/.env on the server and fill values
# NEVER commit the actual .env file to git
# =============================================================

# --- Django Core ---
DJANGO_ENV=production
SECRET_KEY=GENERATE-A-NEW-50-CHAR-RANDOM-KEY-HERE
DEBUG=False
ALLOWED_HOSTS=161.35.79.174,localhost,127.0.0.1
SITE_URL=http://161.35.79.174

# --- Database (Supabase PostgreSQL) ---
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR-SUPABASE-DB-PASSWORD
DB_HOST=db.YOUR-PROJECT-ID.supabase.co
DB_PORT=5432

# --- CORS / CSRF ---
CORS_ALLOWED_ORIGINS=http://161.35.79.174
CSRF_TRUSTED_ORIGINS=http://161.35.79.174

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@eiscomtech.com
ADMIN_EMAIL=admin@eiscomtech.com

# --- Tenant ---
TENANT_ROUTING_STRATEGY=path
TENANT_PATH_PREFIX=workspace
TENANT_EXCLUDED_PATHS=/admin,/static,/media,/health

# --- Stripe ---
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET
REQUIRE_PAYMENT_FOR_REGISTRATION=True

# --- Redis (optional — enable if using Celery or cache) ---
# REDIS_URL=redis://127.0.0.1:6379/0

# --- Sentry (optional — error tracking) ---
# SENTRY_DSN=https://your-sentry-dsn
