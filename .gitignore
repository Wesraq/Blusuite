# ============================================================
# BLU Suite — comprehensive .gitignore
# ============================================================

# --- Environment / Secrets (NEVER commit these) ---
.env
.env.*
!.env.example
!.env.production.example

# --- SSH / Key files ---
*.pem
*.key
*_ssh_key.txt
digitalocean_ssh_key.txt
my_ssh_key.txt

# --- Database ---
db.sqlite3
*.sqlite3
*.db

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual environment ---
venv/
env/
ENV/
.venv/
.env/

# --- Django generated ---
staticfiles/
media/

# --- Logs ---
logs/*.log
*.log

# --- Node ---
node_modules/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Archives / Packages ---
*.tar.gz
*.zip
*.rar
blusuite*.tar.gz
blusuite*.zip

# --- Celery ---
celerybeat-schedule
celerybeat.pid

# --- Coverage ---
htmlcov/
.tox/
.coverage
.coverage.*
coverage.xml

# --- Pytest ---
.pytest_cache/
.cache/
node_modules

# --- Dev artefacts ---
ems_project/_BACKUP_CLEANUP_2026/
docs/
