# Django Settings
DJANGO_ENV=development
SECRET_KEY=your-secret-key-here-CHANGE-THIS-IN-PRODUCTION
DEBUG=True

# Database (Development uses SQLite, Production should use PostgreSQL)
# For production, uncomment and configure:
# DB_NAME=blusuite_db
# DB_USER=blusuite_user
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432

# Allowed Hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost

# CORS Settings (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# CSRF Trusted Origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# Site Configuration
SITE_URL=http://127.0.0.1:8000

# Tenant Configuration
TENANT_ROUTING_STRATEGY=path
TENANT_PATH_PREFIX=workspace
TENANT_EXCLUDED_PATHS=/admin,/static,/media,/health

# Stripe Payment Configuration (NEVER commit real keys to git)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Payment Settings
REQUIRE_PAYMENT_FOR_REGISTRATION=True
DEFAULT_CURRENCY=USD
DEFAULT_PAYMENT_PLAN_PRICE=29.99

# Redis (for production caching and Celery)
# REDIS_URL=redis://127.0.0.1:6379/0

# Sentry (Error Tracking - Production only)
# SENTRY_DSN=your-sentry-dsn-here
